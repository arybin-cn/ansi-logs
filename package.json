{
  "name": "ansi-logs",
  "displayName": "ANSI Logs",
  "description": "High-performance ANSI log viewer with virtual scrolling, log-level filtering, inline editing, grep filter, and tail-follow. Handles 2M+ line log files with ease.",
  "version": "0.1.0",
  "publisher": "bartag",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/bartag/ansi-logs"
  },
  "bugs": {
    "url": "https://github.com/bartag/ansi-logs/issues"
  },
  "homepage": "https://github.com/bartag/ansi-logs#readme",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "keywords": ["log", "ansi", "color", "viewer", "pretty", "logger", "tail", "grep", "large file"],
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "ansiLogs.logViewer",
        "displayName": "ANSI Logs",
        "selector": [
          { "filenamePattern": "*.log" },
          { "filenamePattern": "*.log.*" }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "ansiLogs.openRaw",
        "title": "ANSI Logs: Open as Text Editor"
      },
      {
        "command": "ansiLogs.toggleViewer",
        "title": "ANSI Logs: Toggle Log Viewer"
      }
    ],
    "configuration": {
      "title": "ANSI Logs",
      "properties": {
        "ansiLogs.lineHeight": {
          "type": "number",
          "default": 22,
          "description": "Line height in pixels for the log viewer"
        },
        "ansiLogs.fontSize": {
          "type": "number",
          "default": 13,
          "description": "Font size in pixels for the log viewer"
        },
        "ansiLogs.fontFamily": {
          "type": "string",
          "default": "",
          "description": "Font family override (leave empty to use VS Code editor font)"
        },
        "ansiLogs.renderBuffer": {
          "type": "number",
          "default": 100,
          "description": "Number of extra lines to render above/below the visible area"
        }
      }
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^16.0.0",
    "typescript": "^4.9.0"
  }
}
